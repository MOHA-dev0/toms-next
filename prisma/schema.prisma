generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model EmployeeInvitation {
  id        String           @id @default(uuid())
  email     String           @unique
  nameAr    String           @map("name_ar")
  phone     String?
  initial   String?
  role      AppRole
  token     String           @unique
  expiresAt DateTime         @map("expires_at")
  status    InvitationStatus @default(pending)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  @@map("employee_invitations")
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  employee  Employee?
  userRoles UserRole[]

  @@map("users")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  role      AppRole
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

model Employee {
  id                 String              @id @default(uuid())
  userId             String              @unique @map("user_id")
  nameAr             String              @map("name_ar")
  email              String              @unique
  phone              String?
  initial            String
  referenceSequence  Int                 @default(1) @map("reference_sequence")
  isActive           Boolean             @default(true) @map("is_active")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  bookings           Booking[]           @relation("BookingEmployee")
  customersCreated   Customer[]          @relation("CreatedBy")
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentsCreated    Payment[]           @relation("PaymentCreatedBy")
  quotationsSales    Quotation[]         @relation("SalesEmployee")
  referenceSequences ReferenceSequence[]
  vouchersCreated    Voucher[]           @relation("VoucherCreatedBy")

  @@map("employees")
}

model City {
  id                               String               @id @default(uuid())
  nameAr                           String               @map("name_ar")
  nameTr                           String?              @map("name_tr")
  countryAr                        String               @default("تركيا") @map("country_ar")
  countryTr                        String?              @default("Türkiye") @map("country_tr")
  isActive                         Boolean              @default(true) @map("is_active")
  createdAt                        DateTime             @default(now()) @map("created_at")
  hotels                           Hotel[]
  quotationItineraries             QuotationItinerary[]
  quotations                       Quotation[]
  services                         Service[]
  quotations_quotationdestinations Quotation[]          @relation("quotationdestinations")

  @@map("cities")
}

model Hotel {
  id              String           @id @default(uuid())
  cityId          String           @map("city_id")
  nameAr          String           @map("name_ar")
  nameTr          String?          @map("name_tr")
  addressAr       String?          @map("address_ar")
  addressTr       String?          @map("address_tr")
  stars           Int?
  phone           String?
  email           String?
  isActive        Boolean          @default(true) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at")
  city            City             @relation(fields: [cityId], references: [id], onDelete: Cascade)
  quotationHotels QuotationHotel[]
  roomTypes       RoomType[]
  vouchers        Voucher[]

  @@index([cityId], map: "hotels_city_id_idx")
  @@map("hotels")
}

model RoomType {
  id              String           @id @default(uuid())
  hotelId         String           @map("hotel_id")
  nameAr          String           @map("name_ar")
  nameTr          String?          @map("name_tr")
  descriptionAr   String?          @map("description_ar")
  maxOccupancy    Int              @default(2) @map("max_occupancy")
  board           String?          @default("bb")
  basePrice       Decimal?         @default(0.00) @map("base_price") @db.Decimal(10, 2)
  currency        Currency         @default(USD)
  imageUrl        String?          @map("image_url")
  isActive        Boolean          @default(true) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at")
  quotationHotels QuotationHotel[]
  roomPricing     RoomPricing[]
  hotel           Hotel            @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId], map: "room_types_hotel_id_idx")
  @@map("room_types")
}

model RoomPricing {
  id              String           @id @default(uuid())
  roomTypeId      String           @map("room_type_id")
  usage           RoomUsage
  board           BoardType
  purchasePrice   Decimal          @map("purchase_price") @db.Decimal(10, 2)
  sellingPrice    Decimal          @map("selling_price") @db.Decimal(10, 2)
  currency        Currency         @default(USD)
  validFrom       DateTime         @map("valid_from") @db.Date
  validTo         DateTime         @map("valid_to") @db.Date
  isActive        Boolean          @default(true) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at")
  quotationHotels QuotationHotel[]
  roomType        RoomType         @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  @@index([roomTypeId], map: "room_pricing_room_type_id_idx")
  @@map("room_pricing")
}

model Service {
  id                String             @id @default(uuid())
  cityId            String             @map("city_id")
  nameAr            String             @map("name_ar")
  nameEn            String?            @map("name_en")
  descriptionAr     String?            @map("description_ar") @db.Text
  purchasePrice     Decimal            @default(0.00) @map("purchase_price") @db.Decimal(10, 2)
  currency          Currency           @default(USD)
  isActive          Boolean            @default(true) @map("is_active")
  createdAt         DateTime           @default(now()) @map("created_at")
  descriptionEn     String?            @map("description_en") @db.Text
  quotationServices QuotationService[]
  city              City               @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@index([cityId], map: "services_city_id_idx")
  @@map("services")
}

model OtherService {
  id            String   @id @default(uuid())
  nameAr        String   @map("name_ar")
  nameEn        String?  @map("name_en")
  descriptionAr String?  @map("description_ar")
  purchasePrice Decimal  @default(0.00) @map("purchase_price") @db.Decimal(10, 2)
  sellingPrice  Decimal  @default(0.00) @map("selling_price") @db.Decimal(10, 2)
  currency      Currency @default(USD)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("other_services")
}

model Agent {
  id         String      @id @default(uuid())
  nameEn     String      @map("name_en")
  logoUrl    String?     @map("logo_url")
  isActive   Boolean     @default(true) @map("is_active")
  createdAt  DateTime    @default(now()) @map("created_at")
  quotations Quotation[]

  @@map("agents")
}

model Customer {
  id             String      @id @default(uuid())
  nameAr         String      @map("name_ar")
  email          String?
  phone          String
  nationality    String?
  passportNumber String?     @map("passport_number")
  notes          String?     @db.Text
  createdBy      String?     @map("created_by")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  employee       Employee?   @relation("CreatedBy", fields: [createdBy], references: [id])
  payments       Payment[]
  quotations     Quotation[]

  @@index([createdBy], map: "customers_created_by_idx")
  @@map("customers")
}

model Quotation {
  id                           String               @id @default(uuid())
  referenceNumber              String               @unique @map("reference_number")
  customerId                   String               @map("customer_id")
  salesEmployeeId              String               @map("sales_employee_id")
  agentId                      String?              @map("agent_id")
  source                       SourceType           @default(b2c)
  destinationCityId            String?              @map("destination_city_id")
  status                       QuotationStatus      @default(draft)
  startDate                    DateTime             @map("start_date") @db.Date
  endDate                      DateTime             @map("end_date") @db.Date
  adults                       Int                  @default(1)
  children                     Int                  @default(0)
  infants                      Int                  @default(0)
  subtotal                     Decimal              @default(0.00) @map("subtotal") @db.Decimal(12, 2)
  commissionAmount             Decimal              @default(0.00) @map("commission_amount") @db.Decimal(12, 2)
  totalPrice                   Decimal              @default(0.00) @map("total_price") @db.Decimal(12, 2)
  profit                       Decimal              @default(0.00) @map("profit") @db.Decimal(12, 2)
  notes                        String?              @db.Text
  createdAt                    DateTime             @default(now()) @map("created_at")
  updatedAt                    DateTime             @updatedAt @map("updated_at")
  paidAmount                   Decimal              @default(0.00) @map("paid_amount") @db.Decimal(12, 2)
  companyId                    String?              @map("company_id")
  bookings                     Booking[]
  payments                     Payment[]
  quotationCars                QuotationCar[]
  quotationFlights             QuotationFlight[]
  quotationHotels              QuotationHotel[]
  quotationItineraries         QuotationItinerary[]
  passengers                   QuotationPassenger[]
  quotationServices            QuotationService[]
  agent                        Agent?               @relation(fields: [agentId], references: [id])
  company                      Company?             @relation(fields: [companyId], references: [id])
  customer                     Customer             @relation(fields: [customerId], references: [id])
  destinationCity              City?                @relation(fields: [destinationCityId], references: [id])
  salesEmployee                Employee             @relation("SalesEmployee", fields: [salesEmployeeId], references: [id])
  cities_quotationdestinations City[]               @relation("quotationdestinations")

  @@index([agentId], map: "quotations_agent_id_idx")
  @@index([companyId], map: "quotations_company_id_idx")
  @@index([customerId], map: "quotations_customer_id_idx")
  @@index([destinationCityId], map: "quotations_destination_city_id_idx")
  @@index([salesEmployeeId], map: "quotations_sales_employee_id_idx")
  @@map("quotations")
}

model QuotationHotel {
  id               String       @id @default(uuid())
  quotationId      String       @map("quotation_id")
  hotelId          String       @map("hotel_id")
  roomTypeId       String       @map("room_type_id")
  roomPricingId    String?      @map("room_pricing_id")
  checkIn          DateTime     @map("check_in") @db.Date
  checkOut         DateTime     @map("check_out") @db.Date
  nights           Int          @default(1)
  roomsCount       Int          @default(1) @map("rooms_count")
  usage            RoomUsage    @default(dbl)
  board            BoardType    @default(bb)
  purchasePrice    Decimal      @map("purchase_price") @db.Decimal(10, 2)
  sellingPrice     Decimal      @map("selling_price") @db.Decimal(10, 2)
  notes            String?      @db.Text
  originalPrice    Decimal?     @map("original_price") @db.Decimal(10, 2)
  originalCurrency Currency?    @map("original_currency")
  exchangeRate     Decimal?     @map("exchange_rate") @db.Decimal(10, 6)
  createdAt        DateTime     @default(now()) @map("created_at")
  hotel            Hotel        @relation(fields: [hotelId], references: [id])
  quotation        Quotation    @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  roomPricing      RoomPricing? @relation(fields: [roomPricingId], references: [id])
  roomType         RoomType     @relation(fields: [roomTypeId], references: [id])

  @@index([hotelId], map: "quotation_hotels_hotel_id_idx")
  @@index([quotationId], map: "quotation_hotels_quotation_id_idx")
  @@index([roomPricingId], map: "quotation_hotels_room_pricing_id_idx")
  @@index([roomTypeId], map: "quotation_hotels_room_type_id_idx")
  @@map("quotation_hotels")
}

model QuotationService {
  id            String           @id @default(uuid())
  quotationId   String           @map("quotation_id")
  serviceId     String?          @map("service_id")
  providerId    String?          @map("provider_id")
  nameAr        String           @map("name_ar")
  descriptionAr String?          @map("description_ar") @db.Text
  quantity      Int              @default(1)
  purchasePrice Decimal          @map("purchase_price") @db.Decimal(10, 2)
  sellingPrice  Decimal          @map("selling_price") @db.Decimal(10, 2)
  serviceDate   DateTime?        @map("service_date") @db.Date
  createdAt     DateTime         @default(now()) @map("created_at")
  descriptionEn String?          @map("description_en") @db.Text
  quotation     Quotation        @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  service       Service?         @relation(fields: [serviceId], references: [id])
  provider      ServiceProvider? @relation(fields: [providerId], references: [id])

  @@index([quotationId], map: "quotation_services_quotation_id_idx")
  @@index([serviceId], map: "quotation_services_service_id_idx")
  @@index([providerId], map: "quotation_services_provider_id_idx")
  @@map("quotation_services")
}

model QuotationFlight {
  id            String    @id @default(uuid())
  quotationId   String    @map("quotation_id")
  departureDate DateTime  @map("departure_date") @db.Date
  description   String?   @db.Text
  flightType    String    @map("flight_type") @default("domestic")
  passengers    Int       @default(1)
  price         Decimal   @db.Decimal(10, 2)
  currency      Currency  @default(USD)
  totalAmount   Decimal   @map("total_amount") @db.Decimal(12, 2)
  createdAt     DateTime  @default(now()) @map("created_at")
  quotation     Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId], map: "quotation_flights_quotation_id_idx")
  @@map("quotation_flights")
}

model QuotationCar {
  id              String    @id @default(uuid())
  quotationId     String    @map("quotation_id")
  pickupDate      DateTime  @map("pickup_date") @db.Date
  dropoffDate     DateTime  @map("dropoff_date") @db.Date
  description     String?    @db.Text
  days            Int       @default(1)
  pricePerDay     Decimal   @map("price_per_day") @db.Decimal(10, 2)
  currency        Currency  @default(USD)
  totalAmount     Decimal   @map("total_amount") @db.Decimal(12, 2)
  createdAt       DateTime  @default(now()) @map("created_at")
  quotation       Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId], map: "quotation_cars_quotation_id_idx")
  @@map("quotation_cars")
}

model QuotationItinerary {
  id            String    @id @default(uuid())
  quotationId   String    @map("quotation_id")
  dayNumber     Int       @map("day_number")
  date          DateTime  @db.Date
  titleAr       String    @map("title_ar")
  descriptionAr String?   @map("description_ar") @db.Text
  cityId        String?   @map("city_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  city          City?     @relation(fields: [cityId], references: [id])
  quotation     Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([cityId], map: "quotation_itinerary_city_id_idx")
  @@index([quotationId], map: "quotation_itinerary_quotation_id_idx")
  @@map("quotation_itinerary")
}

model Booking {
  id                String        @id @default(uuid())
  referenceNumber   String        @unique @map("reference_number")
  quotationId       String        @map("quotation_id")
  bookingEmployeeId String        @map("booking_employee_id")
  status            BookingStatus @default(pending)
  confirmedAt       DateTime?     @map("confirmed_at")
  notes             String?       @db.Text
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  bookingEmployee   Employee      @relation("BookingEmployee", fields: [bookingEmployeeId], references: [id])
  quotation         Quotation     @relation(fields: [quotationId], references: [id])
  vouchers          Voucher[]

  @@index([bookingEmployeeId], map: "bookings_booking_employee_id_idx")
  @@index([quotationId], map: "bookings_quotation_id_idx")
  @@map("bookings")
}

model Voucher {
  id              String      @id @default(uuid())
  bookingId       String      @map("booking_id")
  voucherType     VoucherType @map("voucher_type")
  voucherCode     String      @unique @map("voucher_code")
  hotelId         String?     @map("hotel_id")
  guestNameAr     String      @map("guest_name_ar")
  guestNameTr     String?     @map("guest_name_tr")
  checkIn         DateTime?   @map("check_in") @db.Date
  checkOut        DateTime?   @map("check_out") @db.Date
  roomTypeAr      String?     @map("room_type_ar")
  roomTypeTr      String?     @map("room_type_tr")
  boardAr         String?     @map("board_ar")
  boardTr         String?     @map("board_tr")
  notesAr         String?     @map("notes_ar") @db.Text
  notesTr         String?     @map("notes_tr") @db.Text
  createdBy       String?     @map("created_by")
  createdAt       DateTime    @default(now()) @map("created_at")
  booking         Booking     @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  createdEmployee Employee?   @relation("VoucherCreatedBy", fields: [createdBy], references: [id])
  hotel           Hotel?      @relation(fields: [hotelId], references: [id])

  @@index([bookingId], map: "vouchers_booking_id_idx")
  @@index([createdBy], map: "vouchers_created_by_idx")
  @@index([hotelId], map: "vouchers_hotel_id_idx")
  @@map("vouchers")
}

model Payment {
  id              String     @id @default(uuid())
  quotationId     String?    @map("quotation_id")
  customerId      String?    @map("customer_id")
  amount          Decimal    @db.Decimal(12, 2)
  paymentMethod   String     @default("نقدي") @map("payment_method")
  paymentDate     DateTime   @default(now()) @map("payment_date") @db.Date
  notes           String?    @db.Text
  createdBy       String?    @map("created_by")
  createdAt       DateTime   @default(now()) @map("created_at")
  receiverName    String?    @map("receiver_name")
  referenceNumber String?    @map("reference_number")
  createdEmployee Employee?  @relation("PaymentCreatedBy", fields: [createdBy], references: [id])
  customer        Customer?  @relation(fields: [customerId], references: [id])
  quotation       Quotation? @relation(fields: [quotationId], references: [id])

  @@index([createdBy], map: "payments_created_by_idx")
  @@index([customerId], map: "payments_customer_id_idx")
  @@index([quotationId], map: "payments_quotation_id_idx")
  @@map("payments")
}

model ReferenceSequence {
  id           String   @id @default(uuid())
  employeeId   String   @map("employee_id")
  year         Int
  lastSequence Int      @default(0) @map("last_sequence")
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, year])
  @@map("reference_sequences")
}

model GlobalRoomType {
  id        String   @id @default(uuid())
  nameAr    String   @map("name_ar")
  nameEn    String   @map("name_en")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("global_room_types")
}

model Company {
  id         String      @id @default(uuid())
  nameEn     String      @map("name_en")
  isActive   Boolean     @default(true) @map("is_active")
  createdAt  DateTime    @default(now()) @map("created_at")
  quotations Quotation[]

  @@map("companies")
}

model QuotationPassenger {
  id          String    @id @default(uuid())
  quotationId String    @map("quotation_id")
  name        String
  type        String    @default("adult")
  passport    String?
  age         Int?      @map("age")
  createdAt   DateTime  @default(now()) @map("created_at")
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId], map: "quotation_passengers_quotation_id_idx")
  @@map("quotation_passengers")
}

model SystemSequence {
  key       String   @id
  lastSeq   Int      @default(0) @map("last_seq")
  prefix    String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_sequences")
}

enum AppRole {
  admin
  sales
  booking
}

enum QuotationStatus {
  draft
  sent
  confirmed
  cancelled
}

enum BookingStatus {
  pending
  confirmed
  cancelled
  completed
}

enum SourceType {
  b2b
  b2c
}

enum VoucherType {
  hotel
  transportation
  other
}

enum BoardType {
  ro
  bb
  hb
  fb
  ai
}

enum RoomUsage {
  sgl
  dbl
  tpl
  quad
}

enum InvitationStatus {
  pending
  accepted
  expired
}

enum Currency {
  USD
  EUR
  TRY
  SAR
  AED
  GBP
}

model ServiceProvider {
  id                String             @id @default(uuid())
  name              String
  isActive          Boolean            @default(true) @map("is_active")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  quotationServices QuotationService[]

  @@map("service_providers")
}
